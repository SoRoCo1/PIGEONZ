{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "site": "pigeonz-portfolio",
      "public": "out",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        }
      ]
    },
    {
      "site": "pigeonz-72578",
      "public": "out",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        }
      ]
    }
  ]
}
